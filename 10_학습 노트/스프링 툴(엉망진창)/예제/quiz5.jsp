<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>quiz5</title>
<style>
* {
	box-sizing: border-box;
}

div.default {
	width: 500px;
	height: 500px;
	margin: 0 auto;
}

header {
	border-style: solid;
	height: 20%;
	text-align: center;
	border-bottom: none; 
}

nav {
	float: left;
	width: 20%;
	height: 40%;
	border-style: solid;
	border-bottom: none; 
	border-right: none;
}

section {
	width: 60%;
	height: 40%;
	border-style: solid;
	float: left;
	border-bottom: none; 
	border-right: none;
}

aside {
	float: right;
	width: 20%;
	height: 40%;
	border-style: solid;
	border-bottom: none; 
}

footer {
	border-style: solid;
	height: 20%;
	clear: both
}

h3 {
	text-align: center;
}
</style>
</head>
<body>
	<div class="default">
		<header>
			<h1>&lt;header&gt;</h1>
		</header>
		<nav>
			<h3>&lt;nav&gt;</h3>
		</nav>
		<section>
			<h3>&lt;section&gt;</h3>
		</section>
		<aside>
			<h3>&lt;aside&gt;</h3>
		</aside>
		<footer>
			<h3>&lt;footer&gt;</h3>
		</footer>
	</div>
</body>
</html>














