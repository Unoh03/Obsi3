<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>quiz3</title>
<style>
* {
	box-sizing: border-box;
}

div.default {
	width: 500px;
	height: 500px;
	margin: 0 auto;
}

header {
	border-style: solid;
	height: 20%;
	text-align: center;
	border-bottom: none;
}

nav {
	float: left;
	width: 30%;
	height: 40%;
	border-style: solid;
	border-bottom: none;
}

section {
	height: 40%;
	border-style: solid;
	border-bottom: none;
}

footer {
	border-style: solid;
	height: 20%;

}

h3 {
	text-align: center;
}
</style>
</head>
<body>
	<div class="default">
		<header>
			<h2>&lt;header&gt;</h2>
		</header>
		<nav>
			<h3>&lt;nav&gt;</h3>
		</nav>
		<section>
			<h3>< section ></h3>
		</section>
		<footer>
			<h3>< footer ></h3>
		</footer>
	</div>
</body>
</html>



